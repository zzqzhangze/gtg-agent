# ── Data Directory ────────────────────────────────────────────────────
# 运行时数据根目录（sessions / mcp / skills）。
# 默认 .omo，可改为其他相对路径或绝对路径。
# DATA_DIR=.omo
# 运行时数据子路径（相对于 DATA_DIR）
# SESSIONS_DB=sessions/graph.db
# MCP_DB=mcp/mcp.db
# SKILLS_DIR=skills

# ── LLM ──────────────────────────────────────────────────────────────
# 兼容任何 OpenAI API 格式的服务（Ollama / OpenAI / vLLM / Azure OpenAI / DeepSeek 等）
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-api-key-here
MODEL_NAME=gpt-4o

# ── Sandbox ──────────────────────────────────────────────────────────
SANDBOX_API_URL=http://127.0.0.1:8080
# SANDBOX_API_KEY=my-secret-api-key-007
# 通过代理连接沙箱（默认 false）
SANDBOX_USE_SERVER_PROXY=false

# ── Sandbox 超时配置 ──────────────────────────────────────────────────
# 沙箱生命周期（秒）：容器创建后多久自动销毁，防止僵尸容器堆积。
# 任务耗时较长时适当调大。设为 0 表示永不超时（需手动 cleanup）。
SANDBOX_LIFETIME_TIMEOUT=1800

# 单条命令执行超时（秒）：沙箱内每条 shell 命令的最大执行时间。
# 智能体在沙箱里的所有操作（find 扫描文件、python script.py 等）均受此限制。
# 如果智能体需要长时间运行的任务（训练模型、大数据处理），调大此值。
# 设为 0 表示不限制（危险——命令可能永远卡死）。
SANDBOX_COMMAND_TIMEOUT=60

# HTTP 请求超时（秒）：读写沙箱文件（上传/下载）等 HTTP 调用的超时。
# 大文件上传时可能需要调大。通常保持默认即可。
SANDBOX_REQUEST_TIMEOUT=30
